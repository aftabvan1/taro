# Database (Neon or local PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/taro

# Auth — REQUIRED, app will not start without this
JWT_SECRET=change-me-to-a-random-string

# Hetzner — server provisioning & SSH access
HETZNER_API_TOKEN=
HETZNER_SERVER_IP=
HETZNER_SSH_PRIVATE_KEY=

# Base domain for instance subdomains (e.g. myinstance.instances.taro.sh)
INSTANCE_DOMAIN=instances.taro.sh

# Composio — third-party integrations
COMPOSIO_API_KEY=your_composio_api_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
