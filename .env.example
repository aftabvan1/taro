# Database (Neon or local PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/taro

# Sync daemon DB — restricted role for Hetzner servers (optional)
# If not set, falls back to DATABASE_URL. See drizzle/migrations/0007_sync_daemon_role.sql
SYNC_DATABASE_URL=

# Auth — REQUIRED, app will not start without this
JWT_SECRET=change-me-to-a-random-string

# Hetzner — server provisioning & SSH access
HETZNER_API_TOKEN=
HETZNER_SERVER_IP=
HETZNER_SSH_PRIVATE_KEY=

# Base domain for instance subdomains (e.g. myinstance.instances.taro.sh)
INSTANCE_DOMAIN=instances.taro.sh
NEXT_PUBLIC_INSTANCE_DOMAIN=instances.taro.sh

# Stripe — billing & subscriptions
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_PORTAL_CONFIG_ID=bpc_...

# Resend — transactional emails
RESEND_API_KEY=re_...
FROM_EMAIL=Taro <noreply@taro.sh>

# Composio — third-party integrations
COMPOSIO_API_KEY=your_composio_api_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
